<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.SpaceColony.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/surface_card_stroke</item>
    </style>

    <style name="TextAppearance.SpaceColony.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="TextAppearance.SpaceColony.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SpaceColony.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Widget.SpaceColony.NavButton" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/nav_chip_radius</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:paddingLeft">14dp</item>
        <item name="android:paddingRight">14dp</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="Widget.SpaceColony.FilledButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
