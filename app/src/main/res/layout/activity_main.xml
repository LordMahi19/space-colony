<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="6dp">

            <Button android:id="@+id/navHome" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" />
            <Button android:id="@+id/navRecruit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Recruit" />
            <Button android:id="@+id/navQuarters" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Quarters" />
            <Button android:id="@+id/navSimulator" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Simulator" />
            <Button android:id="@+id/navMission" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mission" />
            <Button android:id="@+id/navMedbay" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Medbay" />
            <Button android:id="@+id/navStats" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Stats" />
            <Button android:id="@+id/navSave" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Save" />
            <Button android:id="@+id/navLoad" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Load" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>